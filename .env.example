# The Forge — variables de entorno
# Copiar a .env en la raíz del repo (o a apps/api/.env si solo corres la API).
# Ver README-LOCAL.md para ejecución en local.

# Base de datos (Prisma + API). Obligatorio en local.
DATABASE_URL=postgresql://theforge:theforge@localhost:5432/theforge

# API (NestJS)
PORT=3000

# IA — elegir un proveedor. Solo necesario si usas chat/entrevista con IA.
AI_PROVIDER=openai
# OpenAI (si AI_PROVIDER=openai):
OPENAI_API_KEY=

# DBGA / AiAnalysis (Scout: búsqueda). Scrape usa Cheerio (sin API key).
# TAVILY_API_KEY=

# Google (si AI_PROVIDER=google):
# GOOGLE_GENERATIVE_AI_API_KEY=

# Web (Vite). Opcional: URL base del API en build de producción.
# VITE_API_URL=/api

# TheForge MCP / AriadneSpecs (proyectos legacy). Opcional: si no está configurado, listKnownProjects devuelve vacío.
# THEFORGE_MCP_URL=https://ariadne.kreoint.mx/mcp
# MCP_AUTH_TOKEN=           # Bearer token (si el servidor requiere auth)
# MCP_X_M2M_TOKEN=          # Alternativa: X-M2M-Token (AriadneSpecs)
# THEFORGE_MCP_TIMEOUT_MS=60000

# P3009: migración atascada — desbloquear antes de deploy (ej. 20260319130000_agent_checkpoint_mdd_stage)
# PRISMA_RESOLVE_ROLLED_BACK=20260319130000_agent_checkpoint_mdd_stage
