# The Forge — plantilla .env (copiar a `.env` en la raíz o `apps/api/.env`). Ver README-LOCAL.md.
# Flags: activar 1|true|yes|on — desactivar 0|false|off|no (salvo que la variable indique otro criterio).
#
# ── Configuración de plataforma (UI) ─────────────────────────────────────
# La mayoría de tunables (LLM, BullMQ, MCP, Hermes, legacy flags, debug) viven en
# **Ajustes → Sistema** (solo super_admin) y se persisten en `AppConfig`.
# Prioridad runtime: BD → env → default. Deja aquí solo bootstrap e infraestructura.
#
# ── Proveedores IA (UI, no env) ───────────────────────────────────────────
# Claves API, modelos, embeddings, fallbacks y visibilidad de equipo:
# **Ajustes → Proveedores de IA** (instancias tenant + BYOK personal).
# No uses OPENROUTER_API_KEY ni variables similares en env.

# NODE_ENV — Modo Node/Nest. Valores: development | production | test
NODE_ENV=development

# DATABASE_URL — PostgreSQL (Prisma). Formato: postgresql://USER:PASS@HOST:PORT/DB
DATABASE_URL=postgresql://theforge:theforge@localhost:5432/theforge

# REDIS_URL — BullMQ (obligatorio en production). Ej.: redis://localhost:6379
REDIS_URL=

# THEFORGE_RUNTIME_ROLE — all (dev monolito) | http (solo API, encola) | worker (solo BullMQ)
THEFORGE_RUNTIME_ROLE=all

# PORT — Puerto HTTP del API Nest
PORT=3000

# CORS_ORIGINS — Orígenes permitidos (coma). En production es obligatorio definirlo
CORS_ORIGINS=

# WEB_DOMAIN — Host canónico del front (sin https://). Obligatorio para autofill OTP desde Mail
WEB_DOMAIN=

# JWT_SECRET — Firma JWT; obligatorio en production
JWT_SECRET=

# JWT_EXPIRES_IN — Caducidad JWT (SignOptions, ej. 7d). Default en código: 7d
JWT_EXPIRES_IN=7d

# SMTP_* — Correo OTP (obligatorio en production junto a USER/PASS)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=0
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# FALKORDB — Grafo SDD (local/dev)
FALKORDB_SDD_URL=
FALKORDB_URL=redis://localhost:6379

# ── Cifrado de tokens en servidor (infra; no sustituye Ajustes → Proveedores) ──
# TOKEN_MASTER_KEYS — AES-256 para cifrar API keys guardadas en la UI. Ver README.md
TOKEN_MASTER_KEYS=
TOKEN_ACTIVE_KEY_VERSION=1

# ── MCP M2M (obligatorio si usas packages/mcp-server contra la API) ─────────
MCP_M2M_SECRET=

# ── Build web ─────────────────────────────────────────────────────────────
VITE_API_URL=/api

# ── Overrides opcionales (preferir Ajustes → Sistema) ─────────────────────
# Descomenta solo si necesitas override por env sin tocar la UI:
# THEFORGE_MCP_URL=
# HERMES_WEBHOOK_URL=
# HERMES_API_KEY=
# LLM_MAX_TOKENS=131072
# LANGGRAPH_RECURSION_LIMIT=100
# MDD_BULLMQ_CONCURRENCY=2

# ── MCP server / sidecars (no lee apps/api directamente) ────────────────────
# THEFORGE_API_URL=http://theforge-api:3000
# MCP_AUTH_TOKEN=
# MCP_X_M2M_TOKEN=

# ── Operación / scripts ─────────────────────────────────────────────────────
PRISMA_RESOLVE_ROLLED_BACK=
WAIT_FOR_POSTGRES_ATTEMPTS=90
WAIT_FOR_POSTGRES_DELAY_MS=1000
CLEAN_SPEC_PROJECT_ID=3

# --- Desarrollo local (pnpm dev / dev:local) ---
DATABASE_URL=postgresql://theforge:theforge@localhost:5432/theforge
FALKORDB_SDD_URL=redis://localhost:6379
FALKORDB_URL=redis://localhost:6379
REDIS_URL=redis://localhost:6381
JWT_SECRET=local-dev-jwt-secret

# --- Docker / Dokploy ---
# POSTGRES_IMAGE=postgres:15-alpine
# REDIS_IMAGE=redis:7-alpine
