generator client {
  provider      = "prisma-client-js"
  output        = "./src/generated"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Usuario de la aplicación (identidad JWT tras OTP). Propietario de proyectos y sesiones.
model User {
  id        String    @id @default(uuid())
  email     String    @unique
  role      String    @default("developer")
  name      String?
  createdAt DateTime  @default(now())
  /// Secret MCP M2M: criptográfico (32 bytes, 64 hex chars). Único por usuario.
  /// Usado para autenticar peticiones del MCP server como este usuario.
  /// Generado automáticamente en el primer login OTP. Roteable desde la UI.
  mcpSecret String?   @unique
  /// URL del MCP de Ariadne configurada por el usuario (opcional).
  /// Usada para llamar a AriadneSpecs MCP. Si no está definida, se usa el fallback global.
  ariadneMcpUrl String?
  /// Token MCP de Ariadne configurado por el usuario (opcional).
  /// Es el MCP Secret del usuario en Ariadne que actuará como base de conocimientos.
  /// No confundir con mcpSecret (token de TheForge).
  ariadneMcpToken String?
  /// URL del MCP de documentación técnica (Context7 u otro compatible). Opcional; default en código.
  techDocsMcpUrl String?
  /// API key del usuario para Technology Docs MCP (p. ej. CONTEXT7_API_KEY). Por usuario, no plataforma.
  techDocsMcpToken String?
  projects  Project[]
  sessions  Session[]
  changeLogs ChangeLog[]
  documentSnapshots DocumentSnapshot[]
  favorites  FavoriteProject[]
  aiSettings UserAISettings?
  providerConfigs UserProviderConfig[]
  providerInstancesCreated ProviderInstance[] @relation("ProviderInstanceCreatedBy")
  uiMcpInstancesCreated UiMcpInstance[] @relation("UiMcpInstanceCreatedBy")
}

/// Preferencias de IA por usuario (proveedor activo, embeddings).
model UserAISettings {
  userId                 String   @id
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeProvider         String
  /// Instancia de proveedor a nivel tenant activa para el usuario (si enabledForUsers).
  activeTenantInstanceId String?
  activeTenantInstance   ProviderInstance? @relation(fields: [activeTenantInstanceId], references: [id], onDelete: SetNull)
  /// Instancia dedicada para el agente Auditor del grafo MDD (p. ej. Opus). Null = instancia activa.
  mddAuditorTenantInstanceId String?
  mddAuditorTenantInstance   ProviderInstance? @relation("UserMddAuditorInstance", fields: [mddAuditorTenantInstanceId], references: [id], onDelete: SetNull)
  /// Proveedor BYOK para embeddings cuando el activo no los expone (p. ej. anthropic).
  embeddingProvider      String?
  embeddingsEnabled      Boolean  @default(true)
  /// Modelo de imagen para generación visual en EVD (ej: dall-e-3, flux-1.1-pro).
  /// @deprecated Usar pluginUserSettings del plugin EVD; se mantiene por compatibilidad.
  imageModel             String?
  /// Calidad de imagen: low, standard, high.
  imageQuality           String   @default("standard")
  /// Estilo visual: abstract, geometric, organic, corporate.
  imageStyle             String   @default("abstract")
  /// Ajustes por plugin comercial: { [pluginId]: Record<string, unknown> }
  pluginUserSettings     Json?
  /// Modelos de chat extra permitidos para este usuario (super_admin; unión con la instancia tenant).
  allowedChatModels      String[] @default([])
  updatedAt              DateTime @updatedAt
}

/// Instancia de proveedor IA a nivel tenant (gestionada por super_admin).
model ProviderInstance {
  id                     String   @id @default(uuid())
  providerType           String
  slug                   String
  displayName            String
  tokenCiphertext        String   @db.Text
  tokenKeyVersion        Int
  chatModel              String
  chatModelFallbacks     String[] @default([])
  /// Modelo solo para el agente Auditor MDD en esta instancia; vacío = mismo que chatModel.
  auditorChatModel       String?
  embeddingModel         String?
  embeddingDimension     Int?
  sttModel               String?
  visionModel            String?
  imageModel             String?
  baseUrl                String?
  extras                 Json?
  enabledForUsers        Boolean  @default(false)
  allowedChatModels      String[] @default([])
  allowedEmbeddingModels String[] @default([])
  isTenantDefault        Boolean  @default(false)
  createdByUserId        String
  createdByUser          User     @relation("ProviderInstanceCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  userAISettings              UserAISettings[]
  mddAuditorUserAISettings    UserAISettings[] @relation("UserMddAuditorInstance")

  @@unique([providerType, slug])
  @@index([providerType])
  @@index([enabledForUsers])
}

/// Instancia team-wide de un **MCP gráfico** (componentes UI). Gestionada por admin/super_admin.
/// Cuando `isActive && compatible`, The Forge la usa para resolver componentes reales en las
/// secciones UI/UX (MDD/Blueprint), inferir el design system y generar el deliverable "Pantallas".
model UiMcpInstance {
  id               String    @id @default(uuid())
  displayName      String
  url              String
  /// Token M2M cifrado (opcional; algunos MCP no requieren auth).
  tokenCiphertext  String?   @db.Text
  tokenKeyVersion  Int?
  /// Habilitada para el equipo (no borrada/deshabilitada manualmente).
  enabled          Boolean   @default(true)
  /// Instancia activa (solo una a la vez; se usa en generación).
  isActive         Boolean   @default(false)
  /// Visible/seleccionable por el equipo.
  teamVisible      Boolean   @default(true)
  /// Resultado de la última detección de compatibilidad contra el contrato UI de The Forge.
  compatible       Boolean   @default(false)
  /// Adaptador genérico usado cuando el MCP no expone el contrato nativo (p. ej. "kreo").
  adapterId        String?
  contractVersion  String?
  libraryName      String?
  libraryVersion   String?
  /// describe_capabilities crudo + tools detectados (JSON).
  capabilitiesJson Json?
  lastCheckedAt    DateTime?
  createdByUserId  String
  createdByUser    User      @relation("UiMcpInstanceCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([isActive])
  @@index([enabled])
}

/// Configuración BYOK por proveedor (token cifrado + modelos).
model UserProviderConfig {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider        String
  tokenCiphertext String   @db.Text
  tokenKeyVersion Int
  chatModel           String
  chatModelFallbacks  String[] @default([])
  embeddingModel      String?
  /// Dimensión del vector de embeddings (override; si null, se deriva del catálogo).
  embeddingDimension  Int?
  sttModel            String?
  visionModel         String?
  imageModel          String?
  baseUrl             String?
  extras              Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, provider])
  @@index([userId])
}

enum ProjectType {
  NEW
  LEGACY
}

/// Política de adopción SDD: define qué entregables y qué reglas de semáforo aplican al proyecto.
enum ComplexityLevel {
  LOW
  MEDIUM
  HIGH
}

/// Ciclo de vida agéntico: cada proyecto avanza por etapas (MDD, cambios legacy, auditoría, etc.).
/// Entregables SDD "constitucionales" (MDD, semáforo, estimación) viven por etapa, no en Project.
/// `isLegacy` + `theforgeProjectId` en Stage permiten enrutar sin releer Project en cada iteración.
model Stage {
  id               String       @id @default(uuid())
  projectId        String
  project          Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  /// Orden dentro del proyecto (1 = primera etapa activa).
  ordinal          Int          @default(1)
  /// Clave estable p. ej. MDD_DRAFT, LEGACY_IMPACT, EVALUATOR.
  key              String?
  name             String?
  /// Estado del workflow de la etapa (borrador, activa, cerrada).
  workflowStatus   StageStatus  @default(DRAFT)
  /// Constitución SDD (markdown): Master Design Document de 7 secciones para esta etapa.
  mddContent       String?      @db.Text
  /// BRD (markdown): problema, KPIs, alcance de negocio — fase previa al MDD técnico.
  brdContent     String?   @db.Text
  /// Domain inventory SSOT (capabilities, entities, processes, CrudMatrix) — PLAN-CASCADE-90.
  domainInventory Json?
  /// Semáforo SDD (ROJO / AMARILLO / VERDE) derivado del MDD.
  status           Status       @default(ROJO)
  precisionScore   Int          @default(0)
  /// Estado del flujo legacy para esta etapa: { description?, filesToModify?, questions?, answers? }
  /// Cada etapa de un proyecto legacy tiene su propio cambio (CHANGE) o es la línea base (BASELINE).
  legacyChangeState Json?
  /// Proyecto NEW enlazado (integración cross-project; etapa 2+ legacy).
  linkedNewProjectId String?
  /// Copia congelada del handoff importado desde el proyecto NEW.
  handoffSnapshot Json?
  handoffImportedAt DateTime?
  /// Snapshot JSON of SDD deliverables captured for this stage (P0.1).
  deliverableSnapshot Json?
  /// Live SDD deliverables for this stage (writable store for ACTIVE stage).
  specContent          String? @db.Text
  architectureContent  String? @db.Text
  useCasesContent      String? @db.Text
  userStoriesContent   String? @db.Text
  blueprintContent     String? @db.Text
  tasksContent         String? @db.Text
  /// Tasks estructurado v2 (JSON parseado desde tasksContent): dependencias, targetFiles, inferenceRules, etc.
  tasksJson            Json?
  documentAst          Json?
  documentVersion      Int          @default(0)
  apiContractsContent  String? @db.Text
  logicFlowsContent    String? @db.Text
  infraContent         String? @db.Text
  agentGovernanceContent String? @db.Text
  uxUiGuideContent     String? @db.Text
  phase0SummaryContent String? @db.Text
  aemContent           String? @db.Text
  /// Delta change spec (markdown): AS-IS inherited summary + explicit delta for stage 2+.
  changeSpecContent String? @db.Text
  estimation       Estimation?
  /// Redundancia intencional con `Project.projectType === LEGACY` para queries y checkpoints por etapa.
  isLegacy         Boolean      @default(false)
  /// Override opcional; si null, aplica `Project.theforgeProjectId`.
  theforgeProjectId   String?
  /// Memoria de trabajo (corto plazo): último contexto / scratch del agente (JSON).
  shortTermContext Json?
  /// Snapshot (hashes + metadatos) de DBGA/BRD/Benchmark al último MDD finalizado en etapa.
  mddUpstreamBaseline Json?
  episodicMemories EpisodicMemory[]
  documentationGaps DocumentationGap[]
  agentSessionLogs AgentSessionLog[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@unique([projectId, ordinal])
  @@index([projectId])
}

/// Memoria episódica (largo plazo por etapa): trazas de razonamiento, ADRs, críticas del Evaluator (Reflexion).
model EpisodicMemory {
  id        String             @id @default(uuid())
  stageId   String
  stage     Stage              @relation(fields: [stageId], references: [id], onDelete: Cascade)
  kind      EpisodicMemoryKind
  content   String             @db.Text
  metadata  Json?
  createdAt DateTime           @default(now())

  @@index([stageId, createdAt])
}

enum StageStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
  SUPERSEDED
}

enum EpisodicMemoryKind {
  REASONING_TRACE
  ARCHITECTURE_DECISION
  REFLEXION_FEEDBACK
  EVALUATOR_REJECTION
  TOOL_OUTPUT
}

/// Estado de un gap de documentación reportado por un agente implementador.
enum DocumentationGapStatus {
  OPEN
  PENDING_APPROVAL
  QUEUED
  RECONCILING
  RESOLVED
  REJECTED
  DUPLICATE
}

/// Eventos en la línea de tiempo de sesión agéntica (separada del chat Workshop).
enum AgentSessionLogKind {
  GAP_REPORTED
  RECONCILE_QUEUED
  ARTIFACT_UPDATED
  RECONCILE_REJECTED
}

enum Visibility {
  PRIVATE
  SHARED
}

/// Agrupación visual de proyectos en el dashboard (carpetas por grupo).
model ProjectGroup {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  isDefault Boolean   @default(false)
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  projects  Project[]

  @@index([sortOrder, name])
}

model Project {
  id               String       @id @default(uuid())
  userId           String
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  groupId          String
  group            ProjectGroup @relation(fields: [groupId], references: [id], onDelete: Restrict)
  name             String
  /// Privado (solo owner) o compartido (todos los usuarios ven/editan).
  visibility       Visibility   @default(PRIVATE)
  /// Nivel de complejidad / riesgo: gobierna semáforo y qué documentos son obligatorios (efectivo tras confirmación).
  complexity       ComplexityLevel @default(HIGH)
  /// Propuesta HITL pendiente: { level, planSummary, reason } hasta que el usuario confirme en el chat.
  complexityPending Json?
  projectType      ProjectType  @default(NEW)
  theforgeProjectId   String?
  hasUxTeam        Boolean      @default(false)
  /// Referencia de diseño para la Guía UX/UI: slug del catálogo (ej. "stripe", "linear-app") o "auto" para matching automático
  uxGuideDesignRef String?
  stages           Stage[]
  sessions         Session[]
  figmaMapping     Json?
  dbgaContent          String?   @db.Text
  specContent          String?   @db.Text
  architectureContent  String?   @db.Text
  useCasesContent      String?   @db.Text
  userStoriesContent   String?   @db.Text
  blueprintContent     String?   @db.Text
  tasksContent         String?   @db.Text
  tasksJson            Json?
  apiContractsContent  String?   @db.Text
  logicFlowsContent    String?   @db.Text
  infraContent         String?   @db.Text
  /// Scaffold agent-governance/ (JSON: AgentGovernanceScaffold)
  agentGovernanceContent String? @db.Text
  uxUiGuideContent     String?   @db.Text
  phase0SummaryContent String?   @db.Text
  /// UI Screens Spec (markdown): pantallas + componentes reales + props, generado vía MCP gráfico compatible.
  uiScreensContent     String?   @db.Text
  /// Estado del flujo Fase 0 interactivo: "idle" | "interviewing" | "done"
  phase0Status        String?   @default("idle")
  /// Gaps pendientes (JSON)
  phase0Gaps          String?   @db.Text
  /// Contador de preguntas realizadas
  phase0Questions     Int?      @default(0)
  aemContent           String?   @db.Text
  /// Data de plugins comerciales: { [pluginId]: any }. Gestión vía PluginsController.
  pluginData           Json?
  /// Webhook URL for POST /projects/:id/converge/trigger (falls back to CONVERGE_WEBHOOK_URL env).
  convergeWebhookUrl   String?
  /// Optional HMAC secret for converge webhook (header X-TheForge-Signature: sha256=…).
  convergeWebhookSecret String?
  agentCheckpoints     AgentStateCheckpoint[]
  changeLogs           ChangeLog[]
  documentSnapshots    DocumentSnapshot[]
  favoritedBy          FavoriteProject[]
  /// Oculto del dashboard por defecto (fusión archivada, etc.).
  archivedAt           DateTime?
  /// Linaje: [{ projectId, name, mergedAt }] de proyectos fusionados en este.
  mergedFrom           Json?
  /// Suite: sub-proyecto vinculado al producto padre (spec independiente).
  parentProjectId      String?
  parentProject        Project?  @relation("ProjectSuite", fields: [parentProjectId], references: [id], onDelete: SetNull)
  childProjects        Project[] @relation("ProjectSuite")
  /// Proyecto LEGACY AS-IS del que depende este producto NEW (integración).
  linkedLegacyProjectId String?
  linkedLegacyProject   Project?  @relation("ProjectLinksLegacy", fields: [linkedLegacyProjectId], references: [id], onDelete: SetNull)
  linkedFromNewProjects Project[] @relation("ProjectLinksLegacy")
  /// Proyecto NEW que solicita cambios en este legacy.
  linkedNewProjectId String?
  linkedNewProject   Project?  @relation("ProjectLinksNew", fields: [linkedNewProjectId], references: [id], onDelete: SetNull)
  linkedFromLegacyProjects Project[] @relation("ProjectLinksNew")
  /// Handoff estructurado { items: IntegrationHandoffItem[] } desde NEW hacia legacy.
  integrationHandoff Json?
  integrationHandoffUpdatedAt DateTime?
  integrationTracesAsNew IntegrationTrace[] @relation("IntegrationTraceNew")
  integrationTracesAsLegacy IntegrationTrace[] @relation("IntegrationTraceLegacy")
  ariadneLinks         ProjectAriadneLink[]
  createdAt            DateTime  @default(now())

  @@index([userId])
  @@index([groupId])
  @@index([archivedAt])
  @@index([parentProjectId])
  @@index([linkedLegacyProjectId])
  @@index([linkedNewProjectId])
}

/// Enlace persistido Forge ↔ Ariadne (brownfield / parity). Se crea en Forge, no en Ariadne.
model ProjectAriadneLink {
  id                  String   @id @default(uuid())
  projectId           String
  project             Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  ariadneProjectId    String?
  ariadneRepositoryId String?
  gitRemote           String?
  projectKey          String?
  repoSlug            String?
  isPrimary           Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([projectId])
  @@index([ariadneProjectId])
  @@index([ariadneRepositoryId])
  @@index([gitRemote])
  @@index([projectKey, repoSlug])
  @@map("project_ariadne_links")
}

enum IntegrationTraceStatus {
  DRAFT
  SENT
  ACCEPTED
  IMPLEMENTED
  REJECTED
}

/// Trazabilidad NEW-LEG ↔ LEG entre proyectos Workshop enlazados.
model IntegrationTrace {
  id               String                 @id @default(uuid())
  newProjectId     String
  newProject       Project                @relation("IntegrationTraceNew", fields: [newProjectId], references: [id], onDelete: Cascade)
  legacyProjectId  String
  legacyProject    Project                @relation("IntegrationTraceLegacy", fields: [legacyProjectId], references: [id], onDelete: Cascade)
  newLegId         String
  legacyStoryId    String?
  legacyStageId    String?
  screenOrEndpoint String?
  status           IntegrationTraceStatus @default(DRAFT)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@unique([newProjectId, legacyProjectId, newLegId])
  @@index([legacyProjectId])
  @@index([newProjectId])
}

model FavoriteProject {
  id        String   @id @default(uuid())
  userId    String
  projectId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([userId])
}

/// Hilo LangGraph: Fase 0 / DBGA usa `mddStageId` vacío; flujo MDD Manager por etapa usa el id de `Stage`.
model AgentStateCheckpoint {
  id        String   @id @default(uuid())
  threadId  String   @unique
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  /// "" = DBGA/Benchmark compartido; UUID de Stage = Manager MDD de esa etapa.
  mddStageId String  @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, mddStageId])
  @@index([projectId])
}

/// Memoria semántica: preferencias arquitectónicas extraídas al aprobar un MDD.
/// Se inyectan al inicio de Fase 0 para alinear el benchmark al estilo del usuario.
model ArchitecturalPreference {
  id         String   @id @default(uuid())
  projectId  String?
  summary    String   @db.Text
  createdAt  DateTime @default(now())
}

model Session {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chatLog     Json
  contextStep String
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([projectId])
}

model Estimation {
  id             String   @id @default(uuid())
  stageId        String   @unique
  stage          Stage    @relation(fields: [stageId], references: [id], onDelete: Cascade)
  totalHours    Float
  totalMxn      Float
  teamStructure Json
}

enum Status {
  ROJO
  AMARILLO
  VERDE
}

/// Configuración global de la aplicación (clave-valor).
/// Usada para almacenar ajustes de integración externa,
/// ej. `ariadne_mcp_url` y `ariadne_mcp_token`.
/// Bitácora de cambios en documentos del proyecto (SHARED multi-usuario).
/// Cada entrada registra qué campo se modificó, quién lo hizo, y un resumen del cambio.
/// Las entradas se insertan al persistir contenido de documentos (no settings).
model ChangeLog {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Campo del proyecto o stage modificado: "mddContent" | "uxUiGuideContent" | "specContent" | "blueprintContent" | etc.
  field     String
  /// Resumen del cambio generado automáticamente (primeros caracteres del contenido o descripción).
  summary   String   @db.Text
  createdAt DateTime @default(now())

  @@index([projectId, createdAt(sort: Desc)])
}

/// Copia completa de un campo documental antes de sobrescribir (recuperación manual).
model DocumentSnapshot {
  id            String   @id @default(uuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Campo del proyecto: dbgaContent, specContent, …
  field         String
  content       String   @db.Text
  contentLength Int
  /// patch | chat | restore | salvage | generation
  source        String
  createdAt     DateTime @default(now())

  @@index([projectId, field, createdAt(sort: Desc)])
}

/// Gap de documentación SDD reportado vía MCP por un agente implementador.
model DocumentationGap {
  id                String                 @id @default(uuid())
  projectId         String
  stageId           String
  stage             Stage                  @relation(fields: [stageId], references: [id], onDelete: Cascade)
  status            DocumentationGapStatus @default(OPEN)
  /// Artefactos SDD afectados (ej. ["blueprint","tasks"]).
  affectedArtifacts Json
  description       String                 @db.Text
  /// Evidencia: reference (§, T-, docs/sdd/, tasks.md), codePaths, snippet.
  evidence          Json
  /// Hash dedup: project+stage+reference+description normalizado.
  dedupHash         String
  jobId             String?
  createdAt         DateTime               @default(now())
  resolvedAt        DateTime?
  agentSessionLogs  AgentSessionLog[]

  @@index([projectId, createdAt(sort: Desc)])
  @@index([stageId, createdAt(sort: Desc)])
  @@index([dedupHash, createdAt(sort: Desc)])
  @@index([status])
}

/// Línea de tiempo de sesión agéntica (gaps, reconciliaciones, artefactos actualizados).
model AgentSessionLog {
  id        String              @id @default(uuid())
  projectId String
  stageId   String
  stage     Stage               @relation(fields: [stageId], references: [id], onDelete: Cascade)
  kind      AgentSessionLogKind
  gapId     String?
  gap       DocumentationGap?   @relation(fields: [gapId], references: [id], onDelete: SetNull)
  summary   String              @db.Text
  payload   Json?
  createdAt DateTime            @default(now())

  @@index([projectId, stageId, createdAt(sort: Desc)])
  @@index([gapId])
}

model AppConfig {
  key   String @id
  value String
}
